{
  "name": "zoombird-api",
  "version": "1.0.0",
  "description": "ZoomBird Leaderboard API - Cloudflare Workers",
  "main": "worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create zoombird-leaderboard",
    "db:init": "wrangler d1 execute zoombird-leaderboard --file=./schema.sql",
    "db:query": "wrangler d1 execute zoombird-leaderboard --command",
    "db:local": "wrangler d1 execute zoombird-leaderboard --local --command"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "d1",
    "leaderboard",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
